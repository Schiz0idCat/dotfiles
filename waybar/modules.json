{
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "ΎΕι",
            "2": "ΎΞψ",
            "3": "ΎΚρ",
            "4": "≤░Ι╣",
            "8": "ΎΘ┐",
            "9": "ΎΗ╝",
            "10": "≤░ΛΨ",
            "default": "≤░Εδ"
        },
        "persistent-workspaces": {
            "*": [ 1,2,3 ]
        }
    },

    "custom/power": {
        "format": "≤░μΘ",
        "tooltip": false,
        "on-click": "systemctl poweroff",
        "on-click-right": "systemctl hibernate"
    },

    "clock": {
        "format": "{:%d-%m-%y %I:%M} ΎΑΩ ",
        "tooltip": false,
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% {icon}≤▒ΡΜ",
        "format-plugged": "{capacity}% ΎΘο",
        "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣",]
    },

    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["ΎΗΖ"],
        "tooltip": false,
    },

    "network": {
        "format-wifi": "{icon}",
        "format-ethernet": "≤░ΙΑ",
        "format-disconnected": "≤░νφ",
        "linked": "≤░Νβ",
        "tooltip": false,
        "format-icons": {
            "wifi": ["≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
        }
    },

    "bluetooth": {
        "format-on": "≤░Γψ",
        "format-off": "≤░Γ▓",
        "format-connected": "≤░Γ▒",
        "format-disabled": "",
        "format-no-controller": "≤░Γ▓",
        "tooltip": false,
    },

    "pulseaudio": {
        "format": "{volume}% {icon}  {format_source}",
        "format-muted": "≤░ζθ    {format_source}",
        "format-source": "ΎΕ░",
        "format-source-muted": "ΎΕ▒ ",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
        "tooltip": false,
        "format-icons": {
            "headphone": "≤░ΜΜ",
            "headset": "≤░ΜΟ",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
    },

    "cpu": {
        "format": "ΎΜδ {usage}%",
        "tooltip": false
    },

    "memory": {
        "format": "Ό┐Ζ {}%"
    },

    "disk": {
        "interval": 60,
        "format": "ΎΘΑ {percentage_free}%"
    },

    "temperature": {
        "thermal-zone": 10,
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": ["ΎΜΜ", "ΎΜΚ", "ΎΜΘ"],
        "critical-threshold": 80,
        "tooltip": false,
    }
}
